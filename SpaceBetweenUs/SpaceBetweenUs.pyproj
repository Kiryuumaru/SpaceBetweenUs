<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>ebd3b0b2-eeed-45e3-9a69-1ce6428b00e4</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>Run.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>$(SolutionDir)</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>SpaceBetweenUs</Name>
    <RootNamespace>SpaceBetweenUs</RootNamespace>
    <InterpreterId>MSBuild|env|$(MSBuildProjectFullPath)</InterpreterId>
    <LaunchProvider>Standard Python launcher</LaunchProvider>
    <CommandLineArguments>--input Additionals/SampleVideos/test1.mp4</CommandLineArguments>
    <EnableNativeCodeDebugging>False</EnableNativeCodeDebugging>
    <IsWindowsApplication>False</IsWindowsApplication>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="mylib\config.py" />
    <Compile Include="mylib\detection.py" />
    <Compile Include="mylib\distance_calculator.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="mylib\mailer.py" />
    <Compile Include="mylib\thread.py" />
    <Compile Include="mylib\__init__.py" />
    <Compile Include="Run.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="SpaceBetweenUs.py" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="mylib\__pycache__\config.cpython-37.pyc" />
    <Content Include="mylib\__pycache__\detection.cpython-37.pyc" />
    <Content Include="mylib\__pycache__\mailer.cpython-37.pyc" />
    <Content Include="mylib\__pycache__\thread.cpython-37.pyc" />
    <Content Include="mylib\__pycache__\__init__.cpython-37.pyc" />
    <Content Include="requirements.txt" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="mylib\" />
    <Folder Include="mylib\__pycache__\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env\">
      <Id>env</Id>
      <Version>3.7</Version>
      <Description>env (Python 3.7 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
  <!--<Target Name="CoreCompile" />-->
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>