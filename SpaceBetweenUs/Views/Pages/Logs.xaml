<UserControl x:Class="SpaceBetweenUs.Views.Pages.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             mc:Ignorable="d" >
    <Grid Style="{StaticResource ContentRoot}">
        <ScrollViewer>
            <DataGrid ItemsSource="{Binding ViolationLogs}" AutoGenerateColumns="False" >
                <DataGrid.Columns>
                    <mui:DataGridTextColumn Header="Time" Binding="{Binding DateTimeString}" />
                    <mui:DataGridTextColumn Header="Violations" Binding="{Binding ViolationCount}" />
                    <mui:DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected}" />
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</UserControl>
