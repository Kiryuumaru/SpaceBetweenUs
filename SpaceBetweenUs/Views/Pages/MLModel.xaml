<UserControl x:Class="SpaceBetweenUs.Views.Pages.MLModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             mc:Ignorable="d" >
    <Grid Style="{StaticResource ContentRoot}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="FILES NEEDED" Style="{StaticResource Heading2}" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding FileList}" AutoGenerateColumns="False" IsReadOnly="True" >
                <DataGrid.Columns>
                    <mui:DataGridTextColumn Header="File Name"  Binding="{Binding FileName}"/>
                    <mui:DataGridTextColumn Header="Url" Binding="{Binding Url}"/>
                    <mui:DataGridCheckBoxColumn Header="Downloaded" Binding="{Binding Downloaded}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
